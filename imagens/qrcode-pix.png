<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 500 500" width="100%" height="100%">
  <!-- Fundo com Degradê Moderno (Inspirado no Banner) -->
  <defs>
    <linearGradient id="grad_fundo" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#050F22;stop-opacity:1" /> <!-- Azul profundo -->
      <stop offset="100%" style="stop-color:#02050A;stop-opacity:1" /> <!-- Preto -->
    </linearGradient>
  </defs>
  <rect width="500" height="500" rx="40" fill="url(#grad_fundo)" />

  <!-- Detalhe da Borda Externa (Amarelo Ouro) -->
  <rect x="25" y="25" width="450" height="450" rx="35" fill="none" stroke="#FFD152" stroke-width="3" opacity="0.4" />

  <!-- Estrutura do QR Code em Amarelo Ouro (Simulado para Design Perfeito) -->
  <g transform="translate(60, 60)" fill="#FFD152">
    <!-- Olhete Superior Esquerdo -->
    <rect x="0" y="0" width="80" height="80" rx="10" />
    <rect x="15" y="15" width="50" height="50" rx="5" fill="#02050A" />
    <rect x="25" y="25" width="30" height="30" rx="3" />
    
    <!-- Olhete Superior Direito -->
    <rect x="300" y="0" width="80" height="80" rx="10" />
    <rect x="315" y="15" width="50" height="50" rx="5" fill="#02050A" />
    <rect x="325" y="25" width="30" height="30" rx="3" />
    
    <!-- Olhete Inferior Esquerdo -->
    <rect x="0" y="300" width="80" height="80" rx="10" />
    <rect x="15" y="315" width="50" height="50" rx="5" fill="#02050A" />
    <rect x="25" y="325" width="30" height="30" rx="3" />

    <!-- Padrões de dados premium com ícones sutis -->
    <rect x="100" y="10" width="180" height="15" />
    <rect x="100" y="40" width="40" height="15" />
    <rect x="160" y="40" width="120" height="15" />

    <rect x="310" y="100" width="60" height="40" />
    <rect x="320" y="160" width="40" height="100" />

    <rect x="10" y="100" width="70" height="20" />
    <rect x="20" y="140" width="50" height="80" />

    <rect x="100" y="100" width="180" height="180" fill="#02050A" rx="10"/>

    <rect x="100" y="310" width="180" height="60" />
    <rect x="310" y="310" width="60" height="60" />
  </g>

  <!-- Branding Central (DU7 IMPORTS) -->
  <g transform="translate(185, 185)">
    <!-- Fundo do Logo (Azul Escuro para destacar as letras) -->
    <rect width="130" height="130" rx="15" fill="#050F22" stroke="#FFD152" stroke-width="2" />
    
    <!-- Texto do Logo -->
    <text x="65" y="60" fill="#FFFFFF" font-family="'Montserrat', 'Segoe UI', Arial, sans-serif" font-weight="900" font-size="28" text-anchor="middle" letter-spacing="2">DU7</text>
    <text x="65" y="90" fill="#FFD152" font-family="'Segoe UI', Arial, sans-serif" font-weight="bold" font-size="16" text-anchor="middle" letter-spacing="1">IMPORTS</text>
    
    <!-- Linha de detalhe tech -->
    <line x1="25" y1="105" x2="105" y2="105" stroke="#FFD152" stroke-width="1" opacity="0.6" />
  </g>

  <!-- Rodapé do QR Code com Call to Action -->
  <g transform="translate(0, 435)">
    <rect width="500" height="65" rx="0 0 40 40" fill="#05122B" />
    <text x="250" y="30" fill="#FFFFFF" font-family="'Segoe UI', Arial, sans-serif" font-weight="bold" font-size="18" text-anchor="middle">ESCANEIE E RECIBA SEUS ELETRÔNICOS</text>
    <text x="250" y="52" fill="#FFD152" font-family="'Segoe UI', Arial, sans-serif" font-size="12" text-anchor="middle" letter-spacing="1">Rápido • Seguro • DU7 IMPORTS Original</text>
  </g>
</svg>
